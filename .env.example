# Django Core
SECRET_KEY=your-secret-key-here-min-50-chars-use-django-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.local

# Database (PostgreSQL)
DATABASE_URL=postgres://djangoforge:djangoforge@db:5432/djangoforge

# Redis (Celery broker + cache)
REDIS_URL=redis://redis:6379/0

# Stripe Billing
STRIPE_LIVE_MODE=False
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Mailgun via Anymail)
ANYMAIL_MAILGUN_API_KEY=
ANYMAIL_MAILGUN_SENDER_DOMAIN=
DEFAULT_FROM_EMAIL=noreply@djangoforge.dev

# AWS S3 (media file storage — production only)
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Social Auth (Google OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Social Auth (GitHub OAuth)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Sentry Error Tracking
SENTRY_DSN=

# OpenAI (optional — for AI features)
OPENAI_API_KEY=

# Production Security (uncomment for production.py)
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com
